#!/usr/bin/env bash
# pre-push: run boot-smoke when the outgoing commits touch any
# syscall / arch / ABI / kernel surface. Skipped for doc-only or
# tooling-only pushes so the hook stays cheap. Override with
# `SKIP_SMOKE=1 git push ...` when you know you don't need it
# (e.g. a state.md checkpoint).
#
# Install once per clone:
#   git config core.hooksPath .githooks
set -uo pipefail

if [ "${SKIP_SMOKE:-0}" = "1" ]; then
    echo "pre-push: SKIP_SMOKE=1 set, bypassing boot-smoke"
    exit 0
fi

# Read pushed refs from stdin (git's pre-push protocol).
remote_ref_lines="$(cat)"

# Collect every commit being pushed.
shas=""
while read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "${local_sha:-}" ] && continue
    [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # New branch — diff against main.
        range="origin/main..$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi
    shas="$shas $(git rev-list "$range" 2>/dev/null)"
done <<< "$remote_ref_lines"

if [ -z "${shas// /}" ]; then
    exit 0
fi

# Files changed across all pushed commits.
changed="$(git diff --name-only $shas 2>/dev/null | sort -u)"
if [ -z "$changed" ]; then
    exit 0
fi

# Trigger paths — anything that can break boot. Pure-doc, pure-CI,
# and pure-tooling changes skip.
need_smoke=0
while read -r f; do
    [ -z "$f" ] && continue
    case "$f" in
        kernel/*|crates/kernel/*|crates/arch/*|userspace/*|targets/*|vendor/*|rust-toolchain.toml|Cargo.toml|Cargo.lock)
            need_smoke=1
            break
            ;;
    esac
done <<< "$changed"

if [ "$need_smoke" = "0" ]; then
    echo "pre-push: no kernel/userspace/arch changes — skipping boot-smoke"
    exit 0
fi

echo "pre-push: kernel surface changed, running boot-smoke (override with SKIP_SMOKE=1)"
for arch in x86 arm; do
    if ! make "smoke-$arch" SMOKE_TIMEOUT="${SMOKE_TIMEOUT:-300}"; then
        echo "pre-push: FAIL — make smoke-$arch did not reach login" >&2
        echo "         push aborted; fix the boot regression or SKIP_SMOKE=1 to bypass" >&2
        exit 1
    fi
done
echo "pre-push: boot-smoke PASS on both arches"
